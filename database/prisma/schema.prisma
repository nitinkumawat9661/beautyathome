  expiresOn           DateTime?             @map("expires_on") @db.Date
  moderationStatus    MediaModerationStatus @map("moderation_status")
  privateObjectKey    String?               @map("private_object_key") @db.Text
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)

  application VerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, sourceCertificateId], map: "verification_evidence_application_certificate_key")
  @@index([applicationId, createdAt], map: "verification_evidence_application_created_idx")
  @@map("verification_evidence_snapshots")
}

