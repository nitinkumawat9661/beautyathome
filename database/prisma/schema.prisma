  currency            String              @default("INR") @db.Char(3)
  status              WithdrawalStatus    @default(REQUESTED)
  destinationSnapshot Json                @map("destination_snapshot")
  providerPayoutId    String?             @unique(map: "withdrawals_provider_payout_key") @map("provider_payout_id") @db.VarChar(200)
  failureCode         String?             @map("failure_code") @db.VarChar(100)
  internalNote        String?             @map("internal_note") @db.VarChar(2000)
  idempotencyKey      String              @unique(map: "withdrawals_idempotency_key") @map("idempotency_key") @db.VarChar(128)
  requestedAt         DateTime            @default(now()) @map("requested_at") @db.Timestamptz(3)
