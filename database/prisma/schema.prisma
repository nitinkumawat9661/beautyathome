/// may later be replaced without changing the evidence reviewed by Admin.
model VerificationEvidenceSnapshot {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId       String                @map("application_id") @db.Uuid
  sourceCertificateId String                @map("source_certificate_id") @db.Uuid
