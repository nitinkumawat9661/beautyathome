generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  PROFESSIONAL
  ADMIN
  SUPPORT
  FINANCE

  @@map("role")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
  CLOSED

  @@map("user_status")
}

enum VerificationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED

  @@map("verification_status")
}

enum OtpPurpose {
  SIGN_IN
  SIGN_UP
  STEP_UP

  @@map("otp_purpose")
}

enum OtpStatus {
  PENDING
  CONSUMED
  EXPIRED
  LOCKED
  CANCELLED

  @@map("otp_status")
}

enum SessionRevocationReason {
  LOGOUT
  LOGOUT_ALL
  TOKEN_REUSE
  ACCOUNT_STATUS_CHANGED
  ROLE_CHANGED
  ADMINISTRATIVE

  @@map("session_revocation_reason")
}

enum CityStatus {
  ACTIVE
  INACTIVE

  @@map("city_status")
}

enum ServiceAreaStatus {
  ACTIVE
  INACTIVE

  @@map("service_area_status")
}

enum ServiceCategoryStatus {
  ACTIVE
  INACTIVE

  @@map("service_category_status")
}

enum MasterServiceStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("master_service_status")
}

enum ServiceCityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("service_city_status")
}

enum PricePolicyStatus {
  ACTIVE
  INACTIVE

  @@map("price_policy_status")
}

enum MediaModerationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("media_moderation_status")
}

enum ProfessionalServiceState {
  ENABLED
  DISABLED
  SUSPENDED

  @@map("professional_service_state")
}

enum ServiceRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED

  @@map("service_request_status")
}

enum LaunchEligibilityStatus {
  NOT_ASSESSED
  UNDER_REVIEW
  ELIGIBLE
  INELIGIBLE
  SUSPENDED

  @@map("launch_eligibility_status")
}

enum VerificationApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED

  @@map("verification_application_status")
}

enum IsoWeekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("iso_weekday")
}

enum DateOverrideKind {
  AVAILABLE
  UNAVAILABLE

  @@map("date_override_kind")
}

enum AvailabilityStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED
  EXPIRED

  @@map("availability_status")
}

enum AvailabilitySource {
  WEEKLY
  OVERRIDE
  AD_HOC

  @@map("availability_source")
}

enum AuditActorType {
  USER
  SYSTEM
  JOB

  @@map("audit_actor_type")
}

enum AuditOutcome {
  SUCCEEDED
  FAILED
  DENIED

  @@map("audit_outcome")
}

/// A platform identity. Mobile numbers are normalized to E.164 before the API
/// creates the encrypted value and deterministic lookup HMAC stored here.
model User {
  id                               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mobileNumberCiphertext           String     @map("mobile_number_ciphertext") @db.Text
  mobileNumberLookupHash           String     @map("mobile_number_lookup_hash") @db.Char(64)
  mobileNumberEncryptionKeyVersion String     @map("mobile_number_encryption_key_version") @db.VarChar(64)
  mobileVerifiedAt                 DateTime   @map("mobile_verified_at") @db.Timestamptz(3)
  status                           UserStatus @default(ACTIVE)
  createdAt                        DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt                        DateTime?  @map("deleted_at") @db.Timestamptz(3)

  roles                            UserRole[]
  customerProfile                  CustomerProfile?
  professionalProfile              ProfessionalProfile?
  adminProfile                     AdminProfile?
  otpChallenges                    OtpChallenge[]
  authSessions                     AuthSession[]
  serviceCategoriesCreated         ServiceCategory[]             @relation("ServiceCategoryCreator")
  servicesCreated                  Service[]                     @relation("ServiceCreator")
  servicesReviewed                 Service[]                     @relation("ServiceReviewer")
  pricePoliciesCreated             ServiceCityPricePolicy[]      @relation("PricePolicyCreator")
  pricePoliciesReviewed            ServiceCityPricePolicy[]      @relation("PricePolicyReviewer")
  eligibilityReviews               ProfessionalProfile[]         @relation("EligibilityReviewer")
  serviceRequestsReviewed          ProfessionalServiceRequest[]  @relation("ServiceRequestReviewer")
  serviceRequestHistoryEvents      ServiceRequestStatusHistory[] @relation("ServiceRequestHistoryActor")
  verificationApplicationsReviewed VerificationApplication[]     @relation("VerificationReviewer")
  verificationNotesAuthored        VerificationNote[]            @relation("VerificationNoteAuthor")
  verificationHistoryEvents        VerificationStatusHistory[]   @relation("VerificationHistoryActor")
  professionalServicesSuspended    ProfessionalService[]         @relation("ProfessionalServiceSuspender")
  auditEvents                      AuditEvent[]                  @relation("AuditActor")

  @@index([mobileNumberLookupHash], map: "users_mobile_number_lookup_hash_idx")
  @@index([status, deletedAt], map: "users_status_deleted_at_idx")
  @@index([createdAt], map: "users_created_at_idx")
  @@map("users")
}

/// Current role grants. Security-sensitive grant and revoke operations also
/// produce immutable audit events when that module is introduced.
model UserRole {
  userId    String   @map("user_id") @db.Uuid
  role      Role
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role], map: "user_roles_pkey")
  @@index([role, grantedAt], map: "user_roles_role_granted_at_idx")
  @@map("user_roles")
}

model CustomerProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique(map: "customer_profiles_user_id_key") @map("user_id") @db.Uuid
  displayName String?  @map("display_name") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model ProfessionalProfile {
  id                           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                       String                  @unique(map: "professional_profiles_user_id_key") @map("user_id") @db.Uuid
  cityId                       String?                 @map("city_id") @db.Uuid
  displayName                  String?                 @map("display_name") @db.VarChar(100)
  profileImageUploadId         String?                 @map("profile_image_upload_id") @db.Uuid
  profileImageOriginObjectKey  String?                 @map("profile_image_origin_object_key") @db.Text
  profileImagePublicObjectKey  String?                 @map("profile_image_public_object_key") @db.Text
  profileImageModerationStatus MediaModerationStatus?  @map("profile_image_moderation_status")
  biography                    String?                 @db.VarChar(2000)
  experienceYears              Int?                    @map("experience_years")
  languages                    String[]                @default([]) @db.VarChar(35)
  verificationStatus           VerificationStatus      @default(DRAFT) @map("verification_status")
  launchEligibilityStatus      LaunchEligibilityStatus @default(NOT_ASSESSED) @map("launch_eligibility_status")
  eligibilityPolicyVersion     String?                 @map("eligibility_policy_version") @db.VarChar(100)
  eligibilityReviewedByUserId  String?                 @map("eligibility_reviewed_by_user_id") @db.Uuid
  eligibilityReviewedAt        DateTime?               @map("eligibility_reviewed_at") @db.Timestamptz(3)
  isServiceActive              Boolean                 @default(false) @map("is_service_active")
  averageRating                Decimal?                @map("average_rating") @db.Decimal(3, 2)
  ratingCount                  Int                     @default(0) @map("rating_count")
  completedJobs                Int                     @default(0) @map("completed_jobs")
  internalScore                Decimal?                @map("internal_score") @db.Decimal(7, 3)
  internalScoreVersion         String?                 @map("internal_score_version") @db.VarChar(100)
  internalScoreUpdatedAt       DateTime?               @map("internal_score_updated_at") @db.Timestamptz(3)
  version                      Int                     @default(1)
  createdAt                    DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)

  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  city                  City?                        @relation(fields: [cityId], references: [id], onDelete: Restrict)
  eligibilityReviewedBy User?                        @relation("EligibilityReviewer", fields: [eligibilityReviewedByUserId], references: [id], onDelete: SetNull)
  serviceAreas          ProfessionalServiceArea[]
  portfolioAssets       PortfolioAsset[]
  certificates          ProfessionalCertificate[]
  services              ProfessionalService[]
  serviceRequests       ProfessionalServiceRequest[]
  verificationApps      VerificationApplication[]
  availabilitySchedules AvailabilitySchedule[]
  availabilitySlots     AvailabilitySlot[]

  @@index([cityId, verificationStatus, launchEligibilityStatus, isServiceActive], map: "professional_profiles_discovery_status_idx")
  @@map("professional_profiles")
}

/// Staff-facing profile data is separate from role grants. SUPPORT and FINANCE
/// remain least-privilege roles and do not receive implicit ADMIN authority.
model AdminProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique(map: "admin_profiles_user_id_key") @map("user_id") @db.Uuid
  displayName String?  @map("display_name") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

/// Authentication challenges store only keyed digests. The requested role is
/// part of the challenge context so verification cannot be replayed into a
/// different customer, Professional, or staff authorization context.
model OtpChallenge {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String?    @map("user_id") @db.Uuid
  purpose               OtpPurpose
  requestedRole         Role       @map("requested_role")
  status                OtpStatus  @default(PENDING)
  destinationLookupHash String     @map("destination_lookup_hash") @db.Char(64)
  codeDigest            String     @map("code_digest") @db.Char(64)
  providerReference     String?    @map("provider_reference") @db.VarChar(255)
  attemptCount          Int        @default(0) @map("attempt_count")
  maxAttempts           Int        @map("max_attempts")
  requestIpHash         String?    @map("request_ip_hash") @db.Char(64)
  deviceFingerprintHash String?    @map("device_fingerprint_hash") @db.Char(64)
  userAgentHash         String?    @map("user_agent_hash") @db.Char(64)
  expiresAt             DateTime   @map("expires_at") @db.Timestamptz(3)
  consumedAt            DateTime?  @map("consumed_at") @db.Timestamptz(3)
  lastAttemptAt         DateTime?  @map("last_attempt_at") @db.Timestamptz(3)
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([destinationLookupHash, purpose, requestedRole, status, createdAt], map: "otp_challenges_context_idx")
  @@index([userId, createdAt], map: "otp_challenges_user_created_at_idx")
  @@index([status, expiresAt], map: "otp_challenges_status_expires_at_idx")
  @@index([providerReference], map: "otp_challenges_provider_reference_idx")
  @@map("otp_challenges")
}

/// Each record represents one opaque refresh-token generation. `familyId` is
/// the stable session/JWT `sid`; `previousSessionId` creates a linear rotation
/// chain while retaining old hashes for token-reuse detection.
model AuthSession {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String                   @map("user_id") @db.Uuid
  familyId              String                   @default(dbgenerated("gen_random_uuid()")) @map("family_id") @db.Uuid
  activeRole            Role                     @map("active_role")
  previousSessionId     String?                  @unique(map: "auth_sessions_previous_session_id_key") @map("previous_session_id") @db.Uuid
  refreshTokenHash      String                   @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash") @db.Char(64)
  deviceFingerprintHash String?                  @map("device_fingerprint_hash") @db.Char(64)
  deviceName            String?                  @map("device_name") @db.VarChar(120)
  userAgentHash         String?                  @map("user_agent_hash") @db.Char(64)
  createdIpHash         String?                  @map("created_ip_hash") @db.Char(64)
  lastIpHash            String?                  @map("last_ip_hash") @db.Char(64)
  expiresAt             DateTime                 @map("expires_at") @db.Timestamptz(3)
  lastUsedAt            DateTime?                @map("last_used_at") @db.Timestamptz(3)
  lastStepUpAt          DateTime?                @map("last_step_up_at") @db.Timestamptz(3)
  rotatedAt             DateTime?                @map("rotated_at") @db.Timestamptz(3)
  revokedAt             DateTime?                @map("revoked_at") @db.Timestamptz(3)
  revocationReason      SessionRevocationReason? @map("revocation_reason")
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousSession AuthSession? @relation("AuthSessionRotation", fields: [previousSessionId], references: [id], onDelete: SetNull)
  nextSession     AuthSession? @relation("AuthSessionRotation")

  @@index([userId, revokedAt, expiresAt], map: "auth_sessions_user_active_idx")
  @@index([familyId, createdAt], map: "auth_sessions_family_created_at_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model City {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String     @db.VarChar(120)
  normalizedName String     @map("normalized_name") @db.VarChar(120)
  slug           String     @unique(map: "cities_slug_key") @db.VarChar(100)
  state          String     @db.VarChar(120)
  countryCode    String     @default("IN") @map("country_code") @db.Char(2)
  timeZone       String     @map("time_zone") @db.VarChar(100)
  status         CityStatus @default(INACTIVE)
  version        Int        @default(1)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  serviceAreas          ServiceArea[]
  professionalProfiles  ProfessionalProfile[]
  serviceAvailability   ServiceCityAvailability[]
  pricePolicies         ServiceCityPricePolicy[]
  professionalServices  ProfessionalService[]
  requestCities         ProfessionalServiceRequestCity[]
  availabilitySchedules AvailabilitySchedule[]
  availabilitySlots     AvailabilitySlot[]

  @@unique([countryCode, state, normalizedName], map: "cities_country_state_normalized_name_key")
  @@index([status, name], map: "cities_status_name_idx")
  @@map("cities")
}

model ServiceArea {
  id                       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId                   String            @map("city_id") @db.Uuid
  name                     String            @db.VarChar(120)
  normalizedName           String            @map("normalized_name") @db.VarChar(120)
  slug                     String            @db.VarChar(100)
  status                   ServiceAreaStatus @default(INACTIVE)
  serviceabilityDefinition Json?             @map("serviceability_definition")
  version                  Int               @default(1)
  createdAt                DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  city          City                      @relation(fields: [cityId], references: [id], onDelete: Restrict)
  professionals ProfessionalServiceArea[]

  @@unique([cityId, slug], map: "service_areas_city_slug_key")
  @@unique([cityId, normalizedName], map: "service_areas_city_normalized_name_key")
  @@index([cityId, status, name], map: "service_areas_city_status_name_idx")
  @@map("service_areas")
}

model ServiceCategory {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId        String?               @map("parent_id") @db.Uuid
  name            String                @db.VarChar(120)
  normalizedName  String                @map("normalized_name") @db.VarChar(120)
  slug            String                @unique(map: "service_categories_slug_key") @db.VarChar(100)
  description     String?               @db.VarChar(2000)
  displayOrder    Int                   @default(0) @map("display_order")
  status          ServiceCategoryStatus @default(INACTIVE)
  version         Int                   @default(1)
  createdByUserId String                @map("created_by_user_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  parent    ServiceCategory?             @relation("ServiceCategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  ServiceCategory[]            @relation("ServiceCategoryTree")
  createdBy User                         @relation("ServiceCategoryCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  services  Service[]
  requests  ProfessionalServiceRequest[]

  @@unique([parentId, normalizedName], map: "service_categories_parent_normalized_name_key")
  @@index([status, displayOrder, name], map: "service_categories_status_display_order_idx")
  @@map("service_categories")
}

model Service {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId             String              @map("category_id") @db.Uuid
  name                   String              @db.VarChar(120)
  normalizedName         String              @map("normalized_name") @db.VarChar(120)
  slug                   String              @db.VarChar(100)
  description            String              @db.VarChar(2000)
  defaultDurationMinutes Int                 @map("default_duration_minutes")
  status                 MasterServiceStatus @default(INACTIVE)
  version                Int                 @default(1)
  createdByUserId        String              @map("created_by_user_id") @db.Uuid
  reviewedByUserId       String?             @map("reviewed_by_user_id") @db.Uuid
  reviewedAt             DateTime?           @map("reviewed_at") @db.Timestamptz(3)
  suspensionReasonCode   String?             @map("suspension_reason_code") @db.VarChar(80)
  suspensionReason       String?             @map("suspension_reason") @db.VarChar(500)
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  category             ServiceCategory              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy            User                         @relation("ServiceCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  reviewedBy           User?                        @relation("ServiceReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  images               ServiceImage[]
  cityAvailability     ServiceCityAvailability[]
  pricePolicies        ServiceCityPricePolicy[]
  professionalServices ProfessionalService[]
  linkedRequests       ProfessionalServiceRequest[]
  availabilitySlots    AvailabilitySlot[]

  @@unique([categoryId, normalizedName], map: "services_category_normalized_name_key")
  @@unique([categoryId, slug], map: "services_category_slug_key")
  @@index([categoryId, status, name], map: "services_category_status_name_idx")
  @@map("services")
}

model ServiceImage {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId               String                @map("service_id") @db.Uuid
  uploadId                String                @unique(map: "service_images_upload_id_key") @map("upload_id") @db.Uuid
  originObjectKey         String?               @map("origin_object_key") @db.Text
  approvedPublicObjectKey String?               @map("approved_public_object_key") @db.Text
  altText                 String                @map("alt_text") @db.VarChar(180)
  displayOrder            Int                   @default(0) @map("display_order")
  moderationStatus        MediaModerationStatus @default(PENDING) @map("moderation_status")
  userSafeRejectionReason String?               @map("user_safe_rejection_reason") @db.VarChar(500)
  createdAt               DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, displayOrder], map: "service_images_service_display_order_key")
  @@index([serviceId, moderationStatus], map: "service_images_service_moderation_idx")
  @@map("service_images")
}

model ServiceCityAvailability {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String            @map("service_id") @db.Uuid
  cityId    String            @map("city_id") @db.Uuid
  status    ServiceCityStatus @default(INACTIVE)
  version   Int               @default(1)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  city    City    @relation(fields: [cityId], references: [id], onDelete: Restrict)

  @@unique([serviceId, cityId], map: "service_city_availability_service_city_key")
  @@index([cityId, status, serviceId], map: "service_city_availability_discovery_idx")
  @@map("service_city_availability")
}

model ServiceCityPricePolicy {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId         String            @map("service_id") @db.Uuid
  cityId            String            @map("city_id") @db.Uuid
  version           Int
  minimumPricePaise Int               @map("minimum_price_paise")
  maximumPricePaise Int               @map("maximum_price_paise")
  currency          String            @default("INR") @db.Char(3)
  status            PricePolicyStatus @default(INACTIVE)
  effectiveFrom     DateTime          @map("effective_from") @db.Timestamptz(3)
  effectiveTo       DateTime?         @map("effective_to") @db.Timestamptz(3)
  createdByUserId   String            @map("created_by_user_id") @db.Uuid
  reviewedByUserId  String?           @map("reviewed_by_user_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  service    Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  city       City                  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  createdBy  User                  @relation("PricePolicyCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  reviewedBy User?                 @relation("PricePolicyReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  offerings  ProfessionalService[]

  @@unique([serviceId, cityId, version], map: "service_city_price_policies_service_city_version_key")
  @@index([serviceId, cityId, status, effectiveFrom], map: "service_city_price_policies_effective_idx")
  @@map("service_city_price_policies")
}

model ProfessionalServiceArea {
  professionalId String   @map("professional_id") @db.Uuid
  serviceAreaId  String   @map("service_area_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  serviceArea  ServiceArea         @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceAreaId], map: "professional_service_areas_pkey")
  @@index([serviceAreaId, professionalId], map: "professional_service_areas_area_professional_idx")
  @@map("professional_service_areas")
}

model PortfolioAsset {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId          String                @map("professional_id") @db.Uuid
  uploadId                String                @unique(map: "portfolio_assets_upload_id_key") @map("upload_id") @db.Uuid
  originObjectKey         String?               @map("origin_object_key") @db.Text
  approvedPublicObjectKey String?               @map("approved_public_object_key") @db.Text
  altText                 String                @map("alt_text") @db.VarChar(180)
  displayOrder            Int                   @default(0) @map("display_order")
  moderationStatus        MediaModerationStatus @default(PENDING) @map("moderation_status")
  userSafeRejectionReason String?               @map("user_safe_rejection_reason") @db.VarChar(500)
