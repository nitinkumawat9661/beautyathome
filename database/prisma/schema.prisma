  @@map("wallet_accounts")
}

model WalletLedgerEntry {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId          String               @map("wallet_id") @db.Uuid
  bookingId         String?              @map("booking_id") @db.Uuid
  withdrawalId      String?              @map("withdrawal_id") @db.Uuid
  reversalOfEntryId String?              @map("reversal_of_entry_id") @db.Uuid
  entryType         String               @map("entry_type") @db.VarChar(60)
  direction         WalletEntryDirection
  state             WalletEntryState
  amountPaise       BigInt               @map("amount_paise")
  availableAt       DateTime?            @map("available_at") @db.Timestamptz(3)
  idempotencyKey    String               @unique(map: "wallet_entries_idempotency_key") @map("idempotency_key") @db.VarChar(128)
  metadata          Json?
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  wallet            WalletAccount        @relation(fields: [walletId], references: [id], onDelete: Restrict)
  withdrawal        Withdrawal?          @relation(fields: [withdrawalId], references: [id], onDelete: Restrict)
  reversalOf        WalletLedgerEntry?   @relation("WalletReversal", fields: [reversalOfEntryId], references: [id], onDelete: Restrict)
  reversals         WalletLedgerEntry[]  @relation("WalletReversal")

  @@index([walletId, state, availableAt], map: "wallet_entries_wallet_state_available_idx")
  @@index([bookingId, createdAt], map: "wallet_entries_booking_created_idx")
  @@map("wallet_ledger_entries")
}

