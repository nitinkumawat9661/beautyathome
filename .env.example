NODE_ENV=development
DATABASE_URL=postgresql://beautyathome:beautyathome@localhost:5432/beautyathome?schema=public
POSTGRES_DB=beautyathome
POSTGRES_USER=beautyathome
POSTGRES_PASSWORD=beautyathome
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false

# Replace both placeholders with one matching RSA PEM key pair, base64 encoded.
JWT_PRIVATE_KEY_BASE64=replace-with-base64-encoded-rsa-private-pem
JWT_PUBLIC_KEY_BASE64=replace-with-base64-encoded-rsa-public-pem
JWT_KEY_ID=local-development
JWT_ISSUER=beautyathome-api
JWT_AUDIENCE=beautyathome-web
JWT_ACCESS_TTL_SECONDS=900
STEP_UP_TTL_SECONDS=600

REFRESH_TOKEN_TTL_SECONDS=2592000
REFRESH_COOKIE_NAME=bah_refresh
REFRESH_COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# Fixed OTP delivery is accepted only outside production and is never returned by the API.
OTP_DELIVERY_MODE=development
OTP_DEV_CODE=123456
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=60

# Generate unique values for every secret before use; never reuse these placeholders.
OTP_HMAC_SECRET=replace-with-unique-otp-hmac-secret
SESSION_TOKEN_SECRET=replace-with-unique-session-token-secret
PII_LOOKUP_SECRET=replace-with-unique-pii-lookup-secret
REQUEST_CONTEXT_SECRET=replace-with-unique-request-context-secret
PAYMENT_MOCK_SECRET=replace-with-unique-payment-mock-secret
PII_ENCRYPTION_KEY_BASE64=replace-with-base64-encoded-32-byte-key
PII_ENCRYPTION_KEY_VERSION=local-v1

# Set only after Legal/Compliance and Operations approve the launch eligibility policy.
# PROFESSIONAL_ELIGIBILITY_POLICY_VERSION=approved-policy-version
