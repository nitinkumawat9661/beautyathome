{
  "name": "@beautyathome/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:admin": "next dev admin-app -p 3001",
    "build": "next build && pnpm build:admin",
    "build:admin": "next build admin-app",
    "typecheck": "tsc --noEmit && tsc --noEmit -p admin-app/tsconfig.json",
    "clean": "rimraf .next admin-app/.next",
    "start": "next start",
    "start:admin": "next start admin-app -p 3001",
    "lint": "eslint src && cd admin-app && eslint ."
  },
  "dependencies": {
    "@beautyathome/auth": "workspace:*",
    "@beautyathome/booking": "workspace:*",
    "@beautyathome/marketplace": "workspace:*",
    "@beautyathome/types": "workspace:*",
    "@beautyathome/ui": "workspace:*",
    "@beautyathome/utils": "workspace:*",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
